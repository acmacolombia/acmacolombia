---
import Layout from '~/layouts/PageLayout.astro';
import { getLangFromUrl, useTranslations } from '~/i18n/utils';
import Headline from '~/components/blog/Headline.astro';
import BlogEventPosts from '~/components/widgets/BlogEventPosts.astro';

const locale = getLangFromUrl(Astro.url);
const t = useTranslations(locale);

const metadata = {
  title: t('nav.events'),
};
---

<Layout metadata={metadata}>
  <section style="max-width:1200px;margin:0 auto;padding:1rem;">
    <Headline><span class="capitalize">Eventos</span></Headline>
    <center><p style="font-size:1.1rem;color:var(--color-muted);">Consulta aqui nuestro calendario actualizado de eventos, talleres, charlas y mas.</p></center>
    <iframe
      src="https://luma.com/embed/calendar/cal-Rm6fnGe9eB88fab/events"
      width="100%"
      height="300"
      style="border: none; overflow: hidden; border-radius:6px;"
      frameborder="0"
      allowfullscreen>
    </iframe>
    <p style="margin-top: 1em;text-align:center;">
      <a href="https://luma.com/acmacolombia?k=c" target="_blank" rel="noopener noreferrer">
        Si no puedes ver el calendario, haz clic aqui.
      </a>
    </p>
  </section>

  <section style="max-width:1200px;margin:0 auto;padding:1rem;">
    <Headline><span class="capitalize">Eventos Destacados</span></Headline>
    <BlogEventPosts />
  </section>
</Layout>
